# Utilisation de la variable d'environnement DOMAIN_NAME définie dans docker-compose
{$DOMAIN_NAME} {
    # Redirige tout le trafic vers le conteneur Nakama sur le port API
    reverse_proxy nakama:7350

    # Configuration CORS pour permettre les requêtes Web (itch.io, etc.)
    header Access-Control-Allow-Origin *
    header Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS"
    header Access-Control-Allow-Headers "Content-Type, Authorization"
}