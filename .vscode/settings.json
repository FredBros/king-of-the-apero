{
    "godotTools.editorPath.godot4": "c:\\Program Files\\Godot4\\Godot_v4.5.1-stable_win64.exe",
    "files.exclude": {
        "**/*.gd.uid": true,
        "**/*.import": true,
        ".godot/": true,
        "export_presets.cfg": true
    },
// Indentation propre pour GDScript
"[gdscript]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false
},
// Rendu plus lisible
"editor.rulers": [
    100
],
"editor.minimap.enabled": false,
// Recherche plus propre
"search.exclude": {
    ".godot/": true,
    "**/*.gd.uid": true
},
// Performance
"files.watcherExclude": {
    "**/.godot/**": true
}
}